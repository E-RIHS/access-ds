{% extends "base.html.jinja" %}

{% block title %}{{ title }}{% endblock %}

{% block head %}
    {{ super() }}
    
    <link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">
    <script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>

    <script src="/static/js/v-jsoneditor.min.js"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/@koumoul/vjsf@2.18.2/dist/main.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@koumoul/vjsf@2.18.2/dist/third-party.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@koumoul/vjsf@2.18.2/dist/main.css">
{% endblock %}

{% block content %}
    <v-banner color="primary" class="elevation-5 px-10">
        <span 
            v-html="title"
            class="white--text 
            text-h4 
            px-10"></span>
    </v-banner>

    <v-container>
        <v-tabs
            v-model="tab"
            show-arrows
            centered>
            <v-tab 
                v-for="item in tabItems" 
                :key="item"
                v-text="item">
            </v-tab>
        </v-tabs>

        <v-card 
            v-if="tab === 0"
            class="mt-6" 
            elevation="0">
            <v-row>
                <v-form ref="form" v-model="isValid">
                    <v-jsf 
                        v-model="instance" 
                        :schema="schema" 
                        :options="formOptions">
                        <template slot="proposed_services2-prepend">
                            <v-btn
                                @click="selectDialog = true"
                                fab
                                dark
                                small
                                color="primary">
                                <v-icon dark>
                                    mdi-wizard-hat
                                </v-icon>
                            </v-btn>
                        </template>       
                    </v-jsf>
                </v-form>
            </v-row>
        </v-card>

        <v-card 
            v-if="tabItems[tab] === 'Debug: schema'"
            class="mt-6" 
            elevation="0">
            <v-jsoneditor 
                ref="schemaEditor" 
                v-model="schema"
                height="30rem"></v-jsoneditor>
        </v-card>

        <v-card 
            v-if="tabItems[tab] === 'Debug: instance'"
            class="mt-6" 
            elevation="0">
            <v-jsoneditor 
                ref="instanceEditor" 
                v-model="instance"
                height="30rem"></v-jsoneditor>
        </v-card>
    </v-container>

